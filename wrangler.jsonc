{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "soulacy",
  "pages_build_output_dir": "./website",
  "compatibility_date": "2026-07-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "website"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
