# Soulacy configuration example
# Copy to ~/.soulacy/soulspace/config.yaml (the workspace; legacy installs
# keep ~/.soulacy/config.yaml — see docs/WORKSPACE.md) and fill in values.
# NEVER commit config.yaml — it may contain secrets.

# ── Agent directories ─────────────────────────────────────────────────────────
# Use ABSOLUTE paths. Relative paths resolve from the working directory at
# startup — unpredictable when launched via LaunchAgent or systemd.
agent_dirs:
    - /Users/yourname/.soulacy/agents

# ── Channels ─────────────────────────────────────────────────────────────────
channels:
    discord:
        enabled: false
        token: ""
        agent_id: assistant              # Create this agent before enabling.
        guild_id: ""
        # Safety defaults: require an explicit wake phrase and ignore servers.
        trigger_phrase: "!soulacy"
        ignore_groups: true
        allowed_chat_ids: ""
        allowed_user_ids: ""
    http:
        enabled: true
    slack:
        enabled: false
        bot_token: ""
        app_token: ""
        agent_id: assistant              # Create this agent before enabling.
        # Safety defaults: require an explicit wake phrase and ignore channels.
        trigger_phrase: "!soulacy"
        ignore_groups: true
        allowed_chat_ids: ""
        allowed_user_ids: ""
    telegram:
        enabled: false
        # Single-bot (simple):
        agent_id: assistant              # Create this agent before enabling.
        token: ""                          # Your Telegram bot token
        # Safety defaults: require an explicit wake phrase and ignore groups.
        trigger_phrase: "!soulacy"
        ignore_groups: true
        allowed_chat_ids: ""
        allowed_user_ids: []              # Allowlist of Telegram user IDs (int64)

        # Multi-bot — one bot per agent. Comment out the three lines above and
        # use this instead:
        # bots:
        #   - token: "BOT_TOKEN_1"
        #     agent_id: assistant
        #     allowed_user_ids: [123456789]
        #   - token: "BOT_TOKEN_2"
        #     agent_id: financial-agent
        #     allowed_user_ids: [123456789]
    whatsapp:
        enabled: false
        # Official Meta WhatsApp Business Cloud API.
        phone_number_id: ""
        access_token: ""
        verify_token: ""
        app_secret: ""
        agent_id: assistant              # Create this agent before enabling.
        # Safety defaults: require an explicit wake phrase.
        trigger_phrase: "!soulacy"
        allowed_user_ids: ""
    whatsapp_web:
        enabled: false
        # Experimental QR-linked WhatsApp Web sidecar. Not the official
        # WhatsApp Business API; use only for personal/local automation.
        command: node
        args:
            - scripts/whatsapp-web-sidecar.mjs
        session_dir: /Users/yourname/.soulacy/whatsapp-web
        account_id: default
        agent_id: assistant              # Create this agent before enabling.
        # Safety defaults: do not respond to every WhatsApp message.
        trigger_phrase: "!soulacy"
        ignore_groups: true
        allowed_chat_ids: ""
        allowed_sender_ids: ""

# ── LLM providers ─────────────────────────────────────────────────────────────
llm:
    default_provider: ollama
    providers:
        anthropic:
            api_key: "sk-ant-..."          # Your Anthropic API key
            base_url: https://api.anthropic.com
            model: claude-sonnet-4-6
            prompt_caching: true           # Cache system prompt + tools — 90% off repeated input tokens (recommended)
        groq:
            api_key: "gsk_..."             # Your Groq API key
            base_url: https://api.groq.com/openai/v1
            model: qwen/qwen3-32b
        ollama:
            base_url: http://localhost:11434
            model: llama3.3:70b

# ── Realtime voice (Story 11, docs/VOICE_SPIKE.md) ────────────────────────────
# Enables the push-to-talk voice panel in Chat. The browser connects to the
# provider directly over WebRTC using a short-lived key minted by the gateway;
# your real API key never reaches the browser. Key comes from
# llm.providers.openai.api_key or the OPENAI_API_KEY env var.
# voice:
#     provider: openai            # only "openai" supported (v1)
#     model: gpt-realtime-mini    # default; gpt-realtime for higher quality
#     # base_url: ""              # override for Azure/compatible endpoints

# ── Logging ───────────────────────────────────────────────────────────────────
log:
    file: /Users/yourname/.soulacy/logs/soulacy.log
    format: console
    level: info

# ── MCP servers ───────────────────────────────────────────────────────────────
# Connected servers are not automatically a security boundary. By default,
# legacy agents see every connected MCP tool; restrict new/sensitive agents with
# SOUL.yaml fields such as:
#
#   mcp_servers: [rocketmoney]                         # allow one server
#   mcp_tools: [mcp__rocketmoney__get_transactions]    # allow one tool
#   mcp_servers: []                                    # allow no MCP tools
mcp:
    servers:
        filesystem:
            args:
                - -y
                - '@modelcontextprotocol/server-filesystem'
                - /Users/yourname/Documents
            command: npx
            transport: stdio
        rocketmoney:
            args:
                - /Users/yourname/.soulacy/mcp-servers/rocketmoney/start.sh
            command: bash
            transport: stdio
            # DO NOT put the cookie in env here — the PATCH /api/v1/mcp/* endpoint
            # rewrites config.yaml and silently strips env vars. Store the cookie
            # in ~/.soulacy/secrets/rocket_money_cookie instead; start.sh reads it
            # from there automatically.

# ── Memory ────────────────────────────────────────────────────────────────────
memory:
    max_history: 50

# ── Runtime ───────────────────────────────────────────────────────────────────
runtime:
    default_max_turns: 30
    max_concurrent_sessions: 100

    # Python interpreter used for all python_file tools.
    # Must match the interpreter you install packages with:
    #   python3.11 -m pip install --break-system-packages feedparser httpx pyyaml
    # Avoid plain "python3" — on macOS it maps to the system 3.9 which has no packages.
    python_bin: python3.11

    tool_timeout: 30s

    # Python sandbox resource caps (Linux rlimits — ignored on macOS).
    # For long-running tools (e.g. the AI podcast pipeline takes ~15 min),
    # set cpu_seconds: 0 to remove the cap.
    # sandbox:
    #   enabled: true
    #   cpu_seconds: 0      # 0 = no cap (default 30)
    #   memory_mb: 0        # 0 = no cap (default 512)
    #   open_files: 256
    #   file_size_mb: 64

    # Optional: write per-session tool-call audit logs as JSONL.
    # audit_dir: /Users/yourname/.soulacy/audit

# ── Server ────────────────────────────────────────────────────────────────────
server:
    api_key: "sy_..."                      # Generate: openssl rand -hex 32 | sed 's/^/sy_/'
    gui_enabled: true
    host: 127.0.0.1
    port: 18789

# ── Plugin settings (Story E17) ──────────────────────────────────────────────
# Arbitrary plugin-specific configuration, keyed by plugin ID. The shape under
# each key is owned by the plugin — the core parser never validates it.
# Secret-looking values (token/secret/password/api_key/credential in the key
# name) are redacted in the config API; the GUI never sees them.
# plugins_config:
#     weather-bot:
#         units: metric
#         cache_ttl: 15m

# ── Package registries (Story E19) ───────────────────────────────────────────
# Sources for `sy skill install <slug>` and the GUI install flow. Entries are
# queried in ascending priority order (lower runs first) with fallback — the
# first registry that resolves a slug wins. Types: http (default; an E19
# registry serving /v1/search + /v1/packages/{slug}) and git (resolves
# github.com/user/my-skill style sources via shallow clone).
# registries:
#     - id: main
#       type: http
#       base_url: https://registry.example.com
#       priority: 10
#       auth_headers:
#           Authorization: "Bearer sk_..."
#       signing_key: "3b6a27bc..."  # hex ed25519 public key; when set, unsigned/tampered packages are refused
#     - id: github
#       type: git
#       priority: 100

# ── External storage sidecars (Story E24) ────────────────────────────────────
# Vector and queue backends can be served by a sidecar process speaking the
# External Storage Protocol (JSON-RPC 2.0 over stdio) — third-party database
# drivers without recompiling. See docs/EXTERNAL_STORAGE_PROTOCOL.md. The
# gateway provisions a per-run shared scratch directory (workspace
# data/scratch/…) and passes it in negotiate.shared_dir; large payloads move
# as files under it. Conformance kit: sdk/extstorage/storagetest.
# vector:
#     backend: external
#     command: /usr/local/bin/my-vector-sidecar
#     args: ["--db", "/var/lib/mydb"]
# queue:
#     backend: external
#     command: /usr/local/bin/my-queue-sidecar
