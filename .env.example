# .env.example — Soulacy environment configuration
#
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed to the repository.
#
# All variables can also be set directly in config.yaml — the env vars
# simply override the file values at runtime.

# ── Server ───────────────────────────────────────────────────────────────────

# Port the gateway listens on (default: 18789)
SOULACY_PORT=18789

# Bind address INSIDE the container/process. Both compose files default this
# to 0.0.0.0 so the container's port mapping (18789:18789) actually forwards
# host traffic — leaving it at Soulacy's default of 127.0.0.1 would make the
# gateway loopback-only inside the container and http://localhost:18789 from
# the host would connection-refuse. Binding to 0.0.0.0 requires an API key
# (SEC-4 guard) — that's SOULACY_API_KEY below.
# SOULACY_SERVER_HOST=0.0.0.0

# Bearer token required on all API calls.
# If left empty, the gateway only starts when bound to localhost (127.0.0.1/::1)
# and runs UNAUTHENTICATED — fine for local development only. Binding to any
# other address (e.g. SOULACY_HOST=0.0.0.0) with an empty key refuses to start
# unless --allow-unauthenticated is passed. Always set a key for production.
# Generate one with: openssl rand -hex 32
SOULACY_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────────────

# Which LLM provider to use by default (ollama | anthropic | openai | gemini)
SOULACY_LLM_DEFAULT_PROVIDER=ollama

# Ollama — local inference (default). Point at a remote Ollama if needed.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Anthropic Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — also works for any OpenAI-compatible endpoint)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (optional)
# GEMINI_API_KEY=...

# ── Storage ──────────────────────────────────────────────────────────────────

# Storage backend: sqlite (default) | postgres
SOULACY_STORAGE_BACKEND=sqlite

# Postgres — REQUIRED when using the full docker-compose.yml stack.
# There is NO default password: docker compose will refuse to start unless
# POSTGRES_PASSWORD is set here (or in the environment). Choose a strong value,
# e.g. generate one with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Postgres DSN — only needed when SOULACY_STORAGE_BACKEND=postgres and you are
# NOT using docker-compose.yml (compose builds the DSN from POSTGRES_PASSWORD).
# SOULACY_STORAGE_POSTGRES_DSN=postgres://soulacy:CHANGE_ME@postgres:5432/soulacy?sslmode=disable

# ── Vector memory ─────────────────────────────────────────────────────────────

# Vector backend: "" (sqlite-vec, built-in) | qdrant
SOULACY_VECTOR_BACKEND=

# Qdrant — only needed when SOULACY_VECTOR_BACKEND=qdrant
# SOULACY_VECTOR_URL=http://qdrant:6333
# SOULACY_VECTOR_COLLECTION=soulacy_memory
# SOULACY_VECTOR_API_KEY=
# SOULACY_VECTOR_DIMS=768

# ── Python executor ───────────────────────────────────────────────────────────

# Executor backend: process (spawn on demand) | pool (pre-forked, faster)
SOULACY_EXECUTOR_BACKEND=pool
SOULACY_EXECUTOR_WORKERS=4

# ── Security & deployment profile (v1.0.0) ────────────────────────────────────

# Deployment profile — controls whether Cohort F's Security Readiness verdict
# blocks or advises. Values:
#   local        — everything is advisory; single-operator laptop use.
#   development  — findings surface without blocking. Default in docker-compose.lite.yml.
#   staging      — advisory, closer scrutiny.
#   production   — BLOCKS launch when a privileged agent is exposed on a shared
#                  channel without accept_privileged_exposure:true on the binding.
#                  Default in docker-compose.yml (the full-stack production compose).
# SOULACY_DEPLOYMENT_PROFILE=production

# Intent gate mode — the workspace-scoped default (Cohort F-Bridge). Per-agent
# security.intent_gate in each SOUL.yaml still wins. Values:
#   off     — no intent gating (never recommended in production).
#   prompt  — default; asks the operator when a high-risk tool call lands on
#             untrusted evidence with a High-severity injection finding.
#   deny    — refuses the same class of tool calls outright. Recommended for
#             production deployments; default in docker-compose.yml.
# SOULACY_SECURITY_INTENT_GATE=deny

# Sandbox — wraps every Python tool call with rlimits (CPU / address space /
# open files / file size). Enabled by default in both compose files.
# SOULACY_RUNTIME_SANDBOX_ENABLED=true

# ── Update manifest (optional) ────────────────────────────────────────────────

# URL to a signed update manifest so `sy update check/install` work without
# passing --manifest each time. Doctor's "updates" check warns when this is
# unset. See docs/deployment/upgrades.md.
# SOULACY_UPDATE_MANIFEST=https://vmodekurti.github.io/soulacy/updates/latest.json

# ── Build ─────────────────────────────────────────────────────────────────────

# Version tag injected into the binary (default: git describe)
# VERSION=v1.0.0
